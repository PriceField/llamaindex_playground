# Your JWT Bearer token (NOT sk-xxx format)
API_KEY=your_jwt_bearer_token_here
API_BASE=your_base_endpoint
MODEL_NAME=claude-sonnet-4-5-20250929

# ============================================================================
# Embedding Model Configuration
# ============================================================================

# Embedding Type: "local" for HuggingFace (offline), "openai" for OpenAI embeddings
EMBED_MODEL_TYPE=local                    # Options: local, openai (default: local)

# HuggingFace Embeddings (when EMBED_MODEL_TYPE=local)
# Popular models:
#   - BAAI/bge-large-en-v1.5 (default, 335M params, high quality)
#   - sentence-transformers/all-MiniLM-L6-v2 (22M params, fast, smaller)
#   - sentence-transformers/all-mpnet-base-v2 (109M params, balanced)
EMBED_MODEL_NAME=BAAI/bge-large-en-v1.5   # HuggingFace model name

# OpenAI Embeddings (when EMBED_MODEL_TYPE=openai)
EMBED_API_KEY=                            # OpenAI API key (uses API_KEY if not set)
EMBED_API_BASE=                           # Custom endpoint (optional, uses default OpenAI)
EMBED_OPENAI_MODEL=text-embedding-ada-002 # OpenAI model (ada-002, text-embedding-3-small, etc.)

# Application Configuration
APP_ENV=development
APP_DEBUG=true

# HuggingFace Token (optional, for higher rate limits)
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=

# LlamaIndex Settings
CHUNK_SIZE=1024
CHUNK_OVERLAP=20

# Indexing Configuration
BATCH_SIZE=10                    # Files per batch (default: 10)
AUTOSAVE_INTERVAL=60             # Seconds between auto-saves (default: 60)

# ============================================================================
# Code-Aware Indexing Configuration
# ============================================================================

# Code Chunking (smaller chunks for code, larger for documentation)
CODE_CHUNK_SIZE=512              # Chunk size for code files (default: 512)
CODE_CHUNK_OVERLAP=50            # Overlap for code chunks (default: 50)
DOC_CHUNK_SIZE=1024              # Chunk size for documentation (default: 1024)
DOC_CHUNK_OVERLAP=20             # Overlap for documentation (default: 20)

# Metadata Extraction
EXTRACT_FUNCTIONS=true           # Extract function definitions
EXTRACT_CLASSES=true             # Extract class definitions
EXTRACT_IMPORTS=true             # Extract import statements
INCLUDE_LINE_NUMBERS=true        # Add line numbers to chunk metadata
PRESERVE_CODE_STRUCTURE=true    # Chunk on function/class boundaries

# Language & File Support
SUPPORTED_LANGUAGES=csharp,python,javascript,typescript,java,go,rust,cpp,c,ruby,php
DEFAULT_EXCLUDE_PATTERNS=node_modules,__pycache__,.git,dist,build,target,.venv,venv,.pytest_cache,.mypy_cache,*.pyc,*.pyo,*.so,*.dll,*.exe

# Query Settings
CODE_SIMILARITY_TOP_K=5          # Number of sources to retrieve (default: 5)
USE_METADATA_FILTERS=true        # Enable metadata-based filtering
INCLUDE_SOURCE_CONTEXT=true      # Include file paths and line numbers in responses
