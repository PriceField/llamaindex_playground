# ============================================================================
# CPU Configuration (Compatible with GPU-created indexes)
# ============================================================================
#
# This configuration is optimized for CPU-only systems or low-end GPUs.
#
# USAGE: Copy this file to .env to use on your CPU system
#        cp .env.example.cpu .env
#
# FEATURES:
#   - CPU-based embedding (no GPU required)
#   - Smaller batch sizes to conserve memory
#   - Reduced chunk sizes for fewer embeddings during indexing
#   - Optimized for querying existing indexes and light indexing
#
# IMPORTANT: Compatible with GPU-created indexes!
#   This configuration uses the SAME embedding model (jinaai/jina-code-embeddings-1.5b)
#   with the SAME dimensions (1536) as the GPU configuration. This ensures you can:
#   - Query indexes created on your GPU system
#   - Share indexes between your GPU and CPU computers
#   - Get identical semantic search results
#
# PERFORMANCE NOTE:
#   - Querying is fast even on CPU (only embeds the query text, not entire codebase)
#   - Indexing will be slower than GPU but remains functional
# ============================================================================

API_KEY=your_jwt_bearer_token_here
API_BASE=your_base_endpoint
MODEL_NAME=claude-4.5-sonnet

# ============================================================================
# Embedding Model Configuration
# ============================================================================

# Embedding Type: "local" for HuggingFace (offline), "openai" for OpenAI embeddings
EMBED_MODEL_TYPE=local                    # Options: local, openai (default: local)

# HuggingFace Embeddings (when EMBED_MODEL_TYPE=local)
# CPU-Compatible Model (MUST match GPU for index compatibility):
#   - jinaai/jina-code-embeddings-1.5b (1536-dim, code-optimized, 1.5B params)
#   - SAME model as GPU configuration for perfect compatibility
#   - Querying is fast on CPU (only embeds query text, not full codebase)
#   - Indexing is slower but functional for small/medium repositories
EMBED_MODEL_NAME=jinaai/jina-code-embeddings-1.5b   # HuggingFace model name
EMBED_DEVICE=cpu                           # Device: cpu for CPU-only operation
EMBED_MODEL_DIMENSION=1536                 # Embedding dimension (MUST match GPU: 1536)

# OpenAI Embeddings (when EMBED_MODEL_TYPE=openai)
EMBED_API_KEY=                            # OpenAI API key (uses API_KEY if not set)
EMBED_API_BASE=                           # Custom endpoint (optional, uses default OpenAI)
EMBED_OPENAI_MODEL=text-embedding-ada-002 # OpenAI model (ada-002, text-embedding-3-small, etc.)

# Application Configuration
APP_ENV=development
APP_DEBUG=true

# HuggingFace Token (optional, for higher rate limits)
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=

# Indexing Configuration - CPU Optimized
BATCH_SIZE=5                     # Files per batch (CPU: 5, GPU: 20, default: 10)
AUTOSAVE_INTERVAL=300             # Seconds between auto-saves (default: 60)

# ============================================================================
# Code-Aware Indexing Configuration - CPU Optimized
# ============================================================================

# Code Chunking (smaller chunks to reduce number of embeddings)
CODE_CHUNK_SIZE=1024              # Chunk size for code files (CPU: 1024, GPU: 2048, default: 512)
CODE_CHUNK_OVERLAP=80             # Overlap for code chunks (CPU: 80, GPU: 150, default: 50)
DOC_CHUNK_SIZE=1536              # Chunk size for documentation (CPU: 1536, GPU: 3072, default: 1024)
DOC_CHUNK_OVERLAP=100             # Overlap for documentation (CPU: 100, GPU: 200, default: 20)

# Metadata Extraction
EXTRACT_FUNCTIONS=true           # Extract function definitions
EXTRACT_CLASSES=true             # Extract class definitions
EXTRACT_IMPORTS=true             # Extract import statements
INCLUDE_LINE_NUMBERS=true        # Add line numbers to chunk metadata
PRESERVE_CODE_STRUCTURE=true    # Chunk on function/class boundaries

# Language & File Support
SUPPORTED_LANGUAGES=csharp,python,javascript,typescript,java,go,rust,cpp,c,ruby,php

# Default Exclude Patterns (comma-separated)
# Categories: version control, build artifacts, Python caches, IDE files, AI tools, OS files, sensitive files
DEFAULT_EXCLUDE_PATTERNS=.git,node_modules,dist,build,target,__pycache__,.venv,venv,ENV,env,.pytest_cache,.mypy_cache,*.pyc,*.pyo,*.egg-info,.vscode,.idea,*.swp,*.swo,.claude,.DS_Store,Thumbs.db,.cache,storage,*.so,*.dll,*.exe,.env

# Query Settings - CPU Optimized
CODE_SIMILARITY_TOP_K=5          # Number of sources to retrieve (CPU: 5, GPU: 10, default: 5)
USE_METADATA_FILTERS=true        # Enable metadata-based filtering
INCLUDE_SOURCE_CONTEXT=true      # Include file paths and line numbers in responses
