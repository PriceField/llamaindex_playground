# ============================================================================
# GPU Configuration for RTX 4070Ti
# ============================================================================
#
# This configuration is optimized for high-performance GPU systems with RTX 4070Ti.
#
# USAGE: Copy this file to .env to use on your GPU system
#        cp .env.example.gpu .env
#
# FEATURES:
#   - GPU-accelerated embedding with CUDA
#   - Larger batch sizes for faster indexing (20 files per batch)
#   - Comprehensive chunk sizes for maximum context
#   - Optimized for repository indexing workloads
#
# COMPATIBILITY: Creates indexes that can be queried from CPU systems
#   - ✅ Uses the same embedding model (jinaai/jina-code-embeddings-1.5b) as CPU config
#   - ✅ Same dimensions (1536) ensure full compatibility
#   - 💡 Recommended workflow: Index on GPU, query on CPU for best performance
#   - ⚠️ Chunk sizes differ (GPU: 2048/3072, CPU: 1024/1536) - see .env.example.cpu
# ============================================================================

API_KEY=your_jwt_bearer_token_here
API_BASE=your_base_endpoint
MODEL_NAME=claude-4.5-sonnet

# ============================================================================
# Embedding Model Configuration
# ============================================================================

# Embedding Type: "local" for HuggingFace (offline), "openai" for OpenAI embeddings
EMBED_MODEL_TYPE=local                    # Options: local, openai (default: local)

# HuggingFace Embeddings (when EMBED_MODEL_TYPE=local)
# GPU-Optimized Model for Code:
#   - jinaai/jina-code-embeddings-1.5b (1536-dim, code-optimized, 1.5B params)
#   - Excellent for code repositories and technical documentation
#   - GPU acceleration provides fast indexing performance
EMBED_MODEL_NAME=jinaai/jina-code-embeddings-1.5b   # HuggingFace model name
EMBED_DEVICE=cuda                          # Device: cuda for GPU acceleration
EMBED_MODEL_DIMENSION=1536                 # Embedding dimension (jina-code: 1536)

# OpenAI Embeddings (when EMBED_MODEL_TYPE=openai)
EMBED_API_KEY=                            # OpenAI API key (uses API_KEY if not set)
EMBED_API_BASE=                           # Custom endpoint (optional, uses default OpenAI)
EMBED_OPENAI_MODEL=text-embedding-ada-002 # OpenAI model (ada-002, text-embedding-3-small, etc.)

# Application Configuration
APP_ENV=development
APP_DEBUG=true

# HuggingFace Token (optional, for higher rate limits)
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=

# Indexing Configuration - GPU Optimized
BATCH_SIZE=20                    # Files per batch (GPU: 20, default: 10)
AUTOSAVE_INTERVAL=300             # Seconds between auto-saves (default: 60)

# ============================================================================
# Code-Aware Indexing Configuration - GPU Optimized
# ============================================================================

# Code Chunking (larger chunks for comprehensive context)
CODE_CHUNK_SIZE=2048              # Chunk size for code files (GPU: 2048, default: 512)
CODE_CHUNK_OVERLAP=150            # Overlap for code chunks (GPU: 150, default: 50)
DOC_CHUNK_SIZE=3072              # Chunk size for documentation (GPU: 3072, default: 1024)
DOC_CHUNK_OVERLAP=200             # Overlap for documentation (GPU: 200, default: 20)

# Metadata Extraction
EXTRACT_FUNCTIONS=true           # Extract function definitions
EXTRACT_CLASSES=true             # Extract class definitions
EXTRACT_IMPORTS=true             # Extract import statements
INCLUDE_LINE_NUMBERS=true        # Add line numbers to chunk metadata
PRESERVE_CODE_STRUCTURE=true    # Chunk on function/class boundaries

# Language & File Support
SUPPORTED_LANGUAGES=csharp,python,javascript,typescript,java,go,rust,cpp,c,ruby,php

# Default Exclude Patterns (comma-separated)
# Categories: version control, build artifacts, Python caches, IDE files, AI tools, OS files, sensitive files
DEFAULT_EXCLUDE_PATTERNS=.git,node_modules,dist,build,target,__pycache__,.venv,venv,ENV,env,.pytest_cache,.mypy_cache,*.pyc,*.pyo,*.egg-info,.vscode,.idea,*.swp,*.swo,.claude,.DS_Store,Thumbs.db,.cache,storage,*.so,*.dll,*.exe,.env

# Query Settings
CODE_SIMILARITY_TOP_K=10          # Number of sources to retrieve (GPU: 10, default: 5)
USE_METADATA_FILTERS=true        # Enable metadata-based filtering
INCLUDE_SOURCE_CONTEXT=true      # Include file paths and line numbers in responses
